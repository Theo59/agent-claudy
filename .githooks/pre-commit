#!/usr/bin/env bash
# Zero-dependency pre-commit hook for agent-claudy.
#   1. checks the syntax of modified JS/CJS/MJS files (node --check);
#   2. blocks any personal absolute path (/Users/<someone>) in shipped CODE (public repo).
# Enabled via: git config core.hooksPath .githooks   (already done at install time).
# Bypass occasionally: git commit --no-verify

set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

fail=0

# 1. JS syntax
while IFS= read -r f; do
  [ -n "$f" ] || continue
  case "$f" in
    *.js | *.cjs | *.mjs)
      if [ -f "$f" ]; then
        node --check "$f" || { echo "✗ Syntaxe invalide : $f"; fail=1; }
      fi
      ;;
  esac
done <<< "$staged"

# 2. Personal paths in code (.md docs may cite example paths)
code=$(printf '%s\n' "$staged" | grep -E '\.(js|cjs|mjs|swift|sh|json|html|css)$' || true)
if [ -n "$code" ]; then
  # shellcheck disable=SC2086
  if grep -nE '/Users/[a-z]' $code 2>/dev/null; then
    echo "✗ Chemin personnel « /Users/... » détecté dans un fichier de code (repo public)."
    fail=1
  fi
fi

exit "$fail"
